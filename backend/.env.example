# Backend environment variables — copy to .env and fill in values.
# DO NOT commit .env.

# Runtime
ENV=dev
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# Database (Supabase / Postgres). Async driver: postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/pampa

# AI provider
ANTHROPIC_API_KEY=

# Finance providers
WALLBIT_API_KEY=
ETHEREUM_RPC_URL=https://ethereum-rpc.publicnode.com

# Credential vault key — generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=
