# Backend environment variables — copy to .env and fill in values.
# DO NOT commit .env.

# Runtime
ENV=dev
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# Database (Supabase / Postgres). Async driver: postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/openfi

# AI provider
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# Finance providers
WALLBIT_API_KEY=
WALLBIT_BASE_URL=https://api.wallbit.io

# Ethereum JSON-RPC endpoints (per network).
# v1 ships testnets + Base mainnet (see docs/deviations.md §9 for the mainnet
# rationale — needed for the live USDC demo). Defaults are public publicnode
# URLs; override with a paid provider for production reliability.
ETHEREUM_RPC_URL_SEPOLIA=https://ethereum-sepolia-rpc.publicnode.com
ETHEREUM_RPC_URL_HOLESKY=https://ethereum-holesky-rpc.publicnode.com
ETHEREUM_RPC_URL_POLYGON_AMOY=https://polygon-amoy-bor-rpc.publicnode.com
ETHEREUM_RPC_URL_ARBITRUM_SEPOLIA=https://arbitrum-sepolia-rpc.publicnode.com
ETHEREUM_RPC_URL_BASE_SEPOLIA=https://base-sepolia-rpc.publicnode.com
ETHEREUM_RPC_URL_BASE=https://base-rpc.publicnode.com

# Credential vault key — generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=
